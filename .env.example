# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ── AI Classification (Claude Haiku) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Job Board Scraping (Apify) ────────────────────────────────────
APIFY_TOKEN=apify_api_...

# ── Email Notifications (Resend) ─────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM=Growleads Signals <signals@resend.dev>
# Default recipient(s) — comma-separated if multiple
# Also configurable via UI (Sources & Config → Notifications)
REPORT_EMAIL_TO=you@example.com

# ── API Security ──────────────────────────────────────────────────
# Leave empty for open access in dev. Set in Railway for production.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=
